{
  "name": "todo-angular",
  "version": "0.0.0",
  "scripts": {
    "postinstall": "ls /bin/jsh || playwright install chromium",
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:watch": "vitest --config vitest.config.ts",
    "test:browser": "vitest --config vitest.config.ts --browser.headless=false",
    "test:ui": "vitest --config vitest.config.ts --ui",
    "test:spec": "vitest --config vitest.config.ts",
    "lint": "ng lint",
    "prettier:write": "prettier --config .prettierrc.json --write .",
    "prettier:check": "prettier --config .prettierrc.json --check .",
    "lint:check": "ng lint",
    "lint:fix": "ng lint --fix",
    "generate:api": "openapi-generator-cli generate -g typescript-angular -i  src/app/openapi/api-docs.yaml -o src/app/openapi-gen"
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/common": "^21.2.11",
    "@angular/compiler": "^21.2.11",
    "@angular/core": "^21.2.11",
    "@angular/forms": "^21.2.11",
    "@angular/platform-browser": "^21.2.11",
    "@angular/router": "^21.2.11",
    "@fortawesome/fontawesome-free": "^7.1.0",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/platform": "^2.5.0",
    "@analogjs/vite-plugin-angular": "^2.5.0",
    "@analogjs/vitest-angular": "2.5.0",
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.11",
    "@openapitools/openapi-generator-cli": "^2.26.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/browser-playwright": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "angular-eslint": "21.1.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jsdom": "^29.1.1",
    "playwright": "^1.54.0",
    "prettier": "^3.7.4",
    "prettier-eslint": "^16.4.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.47.0",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^4.2.0",
    "vitest": "^4.0.0",
    "vitest-browser-angular": "^0.4.0"
  }
}
